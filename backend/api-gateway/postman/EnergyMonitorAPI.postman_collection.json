{
  "info": {
    "name": "Energy Monitor API",
    "_postman_id": "energy-monitor-api",
    "description": "IoT Energy Monitoring Backend API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "url": {
          "raw": "http://localhost:3000/api/health",
          "protocol": "http",
          "host": ["localhost"],
          "port": "3000",
          "path": ["api", "health"]
        }
      }
    },
    {
      "name": "Login",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"admin123\"\n}"
        },
        "url": {
          "raw": "http://localhost:3000/api/auth/login",
          "protocol": "http",
          "host": ["localhost"],
          "port": "3000",
          "path": ["api", "auth", "login"]
        }
      }
    },
    {
      "name": "Refresh Token",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"refreshToken\": \"YOUR_REFRESH_TOKEN\"\n}"
        },
        "url": {
          "raw": "http://localhost:3000/api/auth/refresh",
          "protocol": "http",
          "host": ["localhost"],
          "port": "3000",
          "path": ["api", "auth", "refresh"]
        }
      }
    },
    {
      "name": "Logout",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"refreshToken\": \"YOUR_REFRESH_TOKEN\"\n}"
        },
        "url": {
          "raw": "http://localhost:3000/api/auth/logout",
          "protocol": "http",
          "host": ["localhost"],
          "port": "3000",
          "path": ["api", "auth", "logout"]
        }
      }
    },
    {
      "name": "Get Metrics",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer YOUR_ACCESS_TOKEN"
          }
        ],
        "url": {
          "raw": "http://localhost:3000/api/protected/metrics",
          "protocol": "http",
          "host": ["localhost"],
          "port": "3000",
          "path": ["api", "protected", "metrics"]
        }
      }
    },
    {
      "name": "Metrics History",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer YOUR_ACCESS_TOKEN"
          }
        ],
        "url": {
          "raw": "http://localhost:3000/api/protected/metrics/history?range=24h",
          "protocol": "http",
          "host": ["localhost"],
          "port": "3000",
          "path": [
            "api",
            "protected",
            "metrics",
            "history"
          ],
          "query": [
            {
              "key": "range",
              "value": "24h"
            }
          ]
        }
      }
    }
  ]
}